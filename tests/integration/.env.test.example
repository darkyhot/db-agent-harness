# Скопируйте в .env.test и заполните своими значениями.
# pytest-dotenv (см. requirements-test.txt) подхватит этот файл при -m integration.

# === LLM backend ===
# `deepseek` — дешёвая итерация, `gigachat` — финальный прогон на прод-модели.
TEST_LLM_BACKEND=deepseek

# === DeepSeek (cheap iteration) ===
DEEPSEEK_API_KEY=sk-replace_me
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# === GigaChat (final prod-parity run) ===
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
JPY_API_TOKEN=replace_me_with_real_token
GIGACHAT_MODEL=GigaChat-2-Max
# WSL2 / окружения без Sber CA: выключить SSL-verify. Альтернатива —
# указать путь к pem через GIGACHAT_CA_BUNDLE_FILE.
GIGACHAT_VERIFY_SSL_CERTS=false

# === Тестовый Postgres ===
TEST_PG_HOST=localhost
TEST_PG_PORT=55432
TEST_PG_USER=test
TEST_PG_DB=agent_test
# PGPASSWORD пуст при POSTGRES_HOST_AUTH_METHOD=trust
PGPASSWORD=

# === Объём синтетики (опционально) ===
SYNTH_ROWS=200
